# -----------------------------------------------------------
# ETKİNLİK REZERVASYON SİSTEMİ - ÖRNEK ORTAM DEĞİŞKENLERİ
# -----------------------------------------------------------

# Sunucu Ayarları
PORT=3000

# Veritabanı Bağlantısı (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://kullanici_adi:sifre@localhost:5432/event_db?schema=public"

# Güvenlik & Kimlik Doğrulama
# JWT (JSON Web Token) imzalamak için kullanılacak gizli anahtar
JWT_SECRET="ornek_gizli_anahtar"